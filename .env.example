# OpenAI API - Required for LLM inference and embeddings
OPENAI_API_KEY=

# Mapbox - Required for maps and geocoding (free tier: https://account.mapbox.com/)
MAPBOX_ACCESS_TOKEN=

# Postgres - Set automatically by Docker Compose, override if using external DB
DATABASE_URL=postgresql+asyncpg://cover:cover@localhost:5432/cover
POSTGRES_DB=cover
POSTGRES_USER=cover
POSTGRES_PASSWORD=cover
